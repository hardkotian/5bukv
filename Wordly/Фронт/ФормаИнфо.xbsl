метод ЛокБлагодарим(): Строка
    выбор Язык
    когда "UA"
        возврат "Дякуємо за Ваше звернення!"
    когда "BY"
        возврат "Дзякуем за ваш зварот"
    иначе      
        возврат "Благодарим за Ваше обращение!"   
    ;
;

метод ЛокВикипедия(): Авто|Строка
    выбор Язык
    когда "UA"
        возврат "https://uk.wikipedia.org/wiki/Wordle"
    когда "BY"
        возврат "https://ru.wikipedia.org/wiki/Wordle"        
    иначе
        возврат "https://ru.wikipedia.org/wiki/Wordle"
    ;
;

метод Лок_Основано(): Авто|Строка
    выбор Язык
    когда "UA"
        возврат "Засновано на грі \"Wordle\" Джоша Вордла" 
    когда "BY"
        возврат "Заснавана на гульні \"Wordle\" Джоша Вордла" 
    иначе
        возврат "Основано на игре \"Wordle\" Джоша Уордла"
    ;
;

метод Лок_УгоститьПивом(): Авто|Строка
    выбор Язык
    когда "UA"
        возврат "Почастувати пивом" 
    когда "BY"
        возврат "Пачаставаць півам" 
    иначе
