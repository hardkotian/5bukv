    ;
;

@ВПодсистеме
метод Лок_НажатьЗдесьЧтобыНачать(): Строка
    выбор ТекущийЯзык
    когда "RU"
        возврат "Нажмите эту кнопку на форме вверху слева чтобы начать новую игру"
    когда "UA"
        возврат "Натисніть цю кнопку на формі вгорі ліворуч, щоб почати нову гру"
    когда "BY"
        возврат "Націсніце гэтую кнопку на форме уверсе злева каб пачаць новую гульню"
    иначе
        возврат "Фантастиш"
    ;    
;

метод Лок_СменитьЯзык(): Авто|Строка
    выбор ТекущийЯзык
    когда "RU"
        возврат "Сменить язык"
    когда "UA"
        возврат "Змінити мову"
    когда "BY"
        возврат "Змяніць мову"
    иначе
        возврат "Шпрехен"
    ;
;

метод Лок_ПравилаИгры(): Авто|Строка
    выбор ТекущийЯзык
    когда "RU"
        возврат "Правила игры"
    когда "UA"
        возврат "Правила гри"
    когда "BY"
        возврат "Правілы гульні"
    иначе
        возврат ""
    ;
;

метод Лок_ПодсказкаИнфо(): Авто|Строка
    выбор ТекущийЯзык
    когда "RU"
        возврат "Информация / обратная связь"
    когда "UA"
        возврат "Інформація / зворотній зв'язок"
    когда "BY"
        возврат "Інфармацыя / зваротная сувязь"
    иначе
        возврат ""
    ;
;