    выбор ТекущийЯзык
    когда "RU"
        возврат "Да, сдаюсь"
    когда "UA"
        возврат "Так, здаюся"
    когда "BY"
        возврат "Так, здаюся"
    иначе
        возврат "Йа воль"
    ;    
;

метод Лок_НетПодумаю(): Строка
    выбор ТекущийЯзык
    когда "RU"
        возврат "Нет, еще подумаю"
    когда "UA"
        возврат "Нi, ще подумаю"
    когда "BY"
        возврат "Не, яшчэ падумаю"
    иначе
