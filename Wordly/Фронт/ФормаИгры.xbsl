    ;    
;

метод Лок_НоваяИгру(): Строка
    выбор ТекущийЯзык
    когда "RU"
        возврат "Начать новую игру"
    когда "UA"
        возврат "Почати нову гру"
    когда "BY"
        возврат "Пачаць новую гульню"            
    иначе
